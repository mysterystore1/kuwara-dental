---
interface Props extends astroHTML.JSX.ImgHTMLAttributes {
  defaultSrc: string;
  warmSrc?: string;
  alt: string;
}

const { defaultSrc, warmSrc = defaultSrc, alt, ...props } = Astro.props;

const withBase = (src: string) => {
  if (!src || /^(?:https?:)?\/\//.test(src) || src.startsWith("data:")) {
    return src;
  }

  const base = import.meta.env.BASE_URL || "/";
  return src.startsWith("/")
    ? `${base.replace(/\/$/, "")}${src}`
    : src;
};

const resolvedDefaultSrc = withBase(defaultSrc);
const resolvedWarmSrc = withBase(warmSrc);
---

<img
  src={resolvedDefaultSrc}
  alt={alt}
  data-theme-default={resolvedDefaultSrc}
  data-theme-warm={resolvedWarmSrc}
  {...props}
/>
