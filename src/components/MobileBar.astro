---
import { SITE } from "../data/site";
import DentalIcon from "./DentalIcon.astro";
---

<div class="mobile-fixed-bar">
  <a href={SITE.phoneHref} class="mobile-fixed-bar__item mobile-fixed-bar__item--phone">
    <DentalIcon name="phone" size={18} />
    <span>電話</span>
  </a>
  <a href="/reserve/" class="mobile-fixed-bar__item mobile-fixed-bar__item--reserve">
    <DentalIcon name="calendar" size={18} />
    <span>WEB予約</span>
  </a>
  <a href={SITE.reserve.line} class="mobile-fixed-bar__item mobile-fixed-bar__item--line" target="_blank" rel="noopener">
    <DentalIcon name="chat" size={18} />
    <span>LINE相談</span>
  </a>
</div>

<style>
  .mobile-fixed-bar {
    position: fixed;
    left: 0.9rem;
    right: 0.9rem;
    bottom: 0.9rem;
    z-index: 110;
    display: none;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.55rem;
    padding: 0.5rem;
    border-radius: 1.6rem;
    border: 1px solid rgba(125, 173, 200, 0.16);
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(16px);
    box-shadow: 0 18px 40px rgba(27, 53, 82, 0.12);
  }

  .mobile-fixed-bar__item {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    gap: 0.35rem;
    min-height: 3rem;
    border-radius: 1.15rem;
    font-size: 0.78rem;
    font-weight: 700;
    color: #fff;
  }

  .mobile-fixed-bar__item--phone {
    background: var(--color-primary-dark);
  }

  .mobile-fixed-bar__item--reserve {
    background: var(--color-accent);
  }

  .mobile-fixed-bar__item--line {
    background: var(--color-primary);
  }

  @media (max-width: 768px) {
    .mobile-fixed-bar {
      display: grid;
    }
  }
</style>
