---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/PageHero.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import SectionCTA from "../../../components/SectionCTA.astro";
import { VISUALS } from "../../../data/visualAssets";
---

<BaseLayout
  title="歯がしみる"
  description="歯がしみる症状でお困りの方へ。知覚過敏だけでなく虫歯や歯周病が関わることもあるため、原因を確認して対応します。"
>
  <PageHero
    title="歯がしみる"
    subtitle="キーンとしみる、あの感じ。放っておかないでください。"
    image={VISUALS.consultation.defaultSrc}
    imageWarm={VISUALS.consultation.warmSrc}
  />

  <div class="container-narrow">
    <Breadcrumb items={[{ label: "症状から探す" }, { label: "歯がしみる" }]} />
  </div>

  <section class="section-padding">
    <div class="container-narrow">
      <div class="section-kicker">症状について</div>
      <h2 class="section-title section-title-left">「まだ痛いほどじゃない」と思う段階で、相談できます。</h2>
      <p class="section-lead">
        しみる症状は、虫歯や知覚過敏、歯ぐきの変化など、いくつかの原因で起こります。
        軽いうちに確認しておくと、治療も大きくなりにくくなります。
      </p>
      <div class="symptom-grid">
        <div class="info-panel">
          <ul class="list">
            <li>冷たい飲み物でキーンとする</li>
            <li>甘いものや酸味でしみる</li>
            <li>歯ブラシが触れるとピリッとする</li>
            <li>風が当たるだけで違和感がある</li>
            <li>以前よりもしみる範囲が広がってきた</li>
          </ul>
        </div>
        <div class="note-card">
          <p class="eyebrow">気になったら、それが来院のタイミングです</p>
          <p>
            しみる原因はひとつではありません。知覚過敏なのか、虫歯なのか、
            詰め物のすき間なのかで対応が変わるため、まずは原因を見分けることが大切です。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding section-alt">
    <div class="container-narrow">
      <div class="section-kicker">考えられる原因</div>
      <h2 class="section-title section-title-left">考えられる原因</h2>
      <div class="card-grid">
        <article class="soft-card card">
          <h3>知覚過敏</h3>
          <p>歯の表面が薄くなったり、歯茎が下がることで、刺激が伝わりやすくなった状態です。</p>
        </article>
        <article class="soft-card card">
          <h3>虫歯</h3>
          <p>虫歯が進行すると、冷たいものや甘いものでしみることがあります。初期は自覚しにくい場合もあります。</p>
        </article>
        <article class="soft-card card">
          <h3>歯周病</h3>
          <p>歯茎が下がることで歯の根元が露出し、しみやすくなることがあります。出血を伴うこともあります。</p>
        </article>
        <article class="soft-card card">
          <h3>歯ぎしり・食いしばり</h3>
          <p>歯の表面がすり減ると刺激に敏感になり、しみる症状が出やすくなります。</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-narrow two-col">
      <div>
      <div class="section-kicker">受診の目安</div>
        <h2 class="section-title section-title-left">受診の目安</h2>
        <div class="callout">
          <ul class="list compact">
            <li>しみる日が何日も続いている</li>
            <li>冷たいものだけでなく、甘いものでもしみる</li>
            <li>しみたあとにジンと残る感じがある</li>
            <li>歯ぐきが下がってきた気がする</li>
            <li>しみる場所が増えてきた</li>
          </ul>
        </div>
      </div>
      <div>
        <div class="section-kicker">ご自宅での対応</div>
        <h2 class="section-title section-title-left">応急的な考え方</h2>
        <div class="callout">
          <ul class="list compact">
            <li>歯ブラシはやわらかめのものを使います</li>
            <li>しみる時期は、熱すぎるものや冷たすぎるものを控えます</li>
            <li>力を入れて磨きすぎないようにします</li>
            <li>どんなときにしみるかを覚えておいてください</li>
            <li>気になる段階で受診して、原因を確かめましょう</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding section-alt">
    <div class="container-narrow">
      <div class="section-kicker">関連する診療</div>
      <h2 class="section-title section-title-left">関連する診療ページ</h2>
      <div class="related-links">
        <a href="/services/cavity/" class="related-card card">
          <span class="related-label">虫歯治療</span>
          <span class="related-copy">しみる原因が虫歯かどうか確認したい方へ</span>
          <span class="related-arrow">→</span>
        </a>
        <a href="/services/periodontal/" class="related-card card">
          <span class="related-label">歯周病治療</span>
          <span class="related-copy">歯茎が下がってしみる場合の相談先として</span>
          <span class="related-arrow">→</span>
        </a>
        <a href="/services/preventive/" class="related-card card">
          <span class="related-label">予防歯科</span>
          <span class="related-copy">再発を防ぎたい、しみやすさを減らしたい方へ</span>
          <span class="related-arrow">→</span>
        </a>
      </div>
      <div class="reserve-link-wrap">
        <a href="/reserve/" class="btn-primary">気になった今、相談する</a>
      </div>
    </div>
  </section>

  <SectionCTA
    heading="気になったら、それが来院のタイミングです。"
    text="軽い違和感でも、原因を見分けておくと安心です。大きな治療になる前に、一度見せてください。"
  />
</BaseLayout>

<style>
  .section-kicker {
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .section-title-left {
    text-align: left;
    margin-bottom: 1rem;
  }
  .section-lead {
    max-width: 720px;
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }
  .section-alt {
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, rgba(255,255,255,0) 100%);
  }
  .symptom-grid,
  .two-col {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }
  .info-panel,
  .note-card,
  .callout {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 28px;
    padding: 1.5rem;
    box-shadow: var(--shadow-card);
  }
  .note-card {
    display: grid;
    align-content: start;
    background: linear-gradient(180deg, rgba(43, 107, 138, 0.06), rgba(255,255,255,1));
  }
  .eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .list {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.85rem;
    color: var(--color-text);
  }
  .compact {
    gap: 0.7rem;
  }
  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .soft-card {
    padding: 1.5rem;
  }
  .soft-card h3 {
    font-size: 1.08rem;
    margin-bottom: 0.6rem;
    color: var(--color-text-heading);
  }
  .soft-card p {
    color: var(--color-text-light);
    line-height: 1.8;
    margin: 0;
  }
  .related-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }
  .related-card {
    display: grid;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-text);
    position: relative;
    overflow: hidden;
  }
  .related-card:hover {
    transform: translateY(-2px);
  }
  .related-label {
    font-weight: 700;
    color: var(--color-text-heading);
  }
  .related-copy {
    color: var(--color-text-light);
    line-height: 1.7;
    padding-right: 2rem;
  }
  .related-arrow {
    position: absolute;
    right: 1.25rem;
    bottom: 1.25rem;
    color: var(--color-accent);
    font-size: 1.2rem;
    font-weight: 700;
  }
  .reserve-link-wrap {
    margin-top: 1.5rem;
  }
  @media (max-width: 900px) {
    .symptom-grid,
    .two-col,
    .card-grid,
    .related-links {
      grid-template-columns: 1fr;
    }
  }
</style>
