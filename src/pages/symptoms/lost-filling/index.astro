---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/PageHero.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import SectionCTA from "../../../components/SectionCTA.astro";
---

<BaseLayout
  title="詰め物が取れた"
  description="詰め物や被せ物が取れたときの応急的な考え方、受診の目安、原因をまとめました。取れたままにせず、早めにご相談ください。"
>
  <PageHero
    title="詰め物が取れた"
    subtitle="焦らないで。でも、早めに来てください。"
    image="/images/stock/asian-checkup.jpg"
  />

  <div class="container-narrow">
    <Breadcrumb items={[{ label: "症状から探す" }, { label: "詰め物が取れた" }]} />
  </div>

  <section class="section-padding">
    <div class="container-narrow">
      <div class="section-kicker">症状について</div>
      <h2 class="section-title section-title-left">取れたままでも大丈夫。でも、早めに見せてください。</h2>
      <p class="section-lead">
        詰め物が取れた直後は痛みがなくても、内側で虫歯が進んでいることがあります。
        慌てなくて大丈夫ですが、放置はおすすめしません。
      </p>
      <div class="advice-box">
        <ul class="advice-list">
          <li>
            <strong>取れたものは保管してください</strong>
            <p>状態が良ければそのまま戻せることがあります。小さな容器や清潔な袋に入れてお持ちください。</p>
          </li>
          <li>
            <strong>市販の接着剤で戻さないでください</strong>
            <p>歯や詰め物を傷めることがあり、後の処置が難しくなることがあります。</p>
          </li>
          <li>
            <strong>取れた側で硬いものを噛まないようにしてください</strong>
            <p>歯が欠けやすくなっている場合があります。反対側でやさしく噛むようにしましょう。</p>
          </li>
          <li>
          <strong>早めのご来院をおすすめします</strong>
            <p>放置すると、内部で虫歯が進行することがあります。</p>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section-padding section-alt">
    <div class="container-narrow">
      <div class="section-kicker">考えられる原因</div>
      <h2 class="section-title section-title-left">詰め物が取れる原因</h2>
      <div class="card-grid">
        <article class="soft-card card">
          <h3>接着部分の劣化</h3>
          <p>長く使っているうちに接着力が弱まり、少しずつ外れやすくなることがあります。</p>
        </article>
        <article class="soft-card card">
          <h3>詰め物の下の虫歯</h3>
          <p>詰め物の下で虫歯が進むと、密着が悪くなって外れやすくなります。</p>
        </article>
        <article class="soft-card card">
          <h3>噛み合わせの力</h3>
          <p>歯ぎしりや食いしばりなどで強い力がかかると、外れる原因になります。</p>
        </article>
        <article class="soft-card card">
          <h3>歯のひびや破折</h3>
          <p>歯自体にひびが入ると、詰め物が安定しにくくなることがあります。</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-narrow two-col">
      <div>
      <div class="section-kicker">受診の目安</div>
        <h2 class="section-title section-title-left">受診の目安</h2>
        <div class="callout">
          <ul class="list compact">
            <li>取れたまま数日たってしまった</li>
            <li>しみる、噛むと痛いなどの症状がある</li>
            <li>食べ物が詰まりやすくなった</li>
            <li>欠けた感じやザラつきがある</li>
            <li>歯ぐきまで違和感が出てきた</li>
          </ul>
        </div>
      </div>
      <div>
        <div class="section-kicker">ご自宅での対応</div>
        <h2 class="section-title section-title-left">応急的な考え方</h2>
        <div class="callout">
          <ul class="list compact">
            <li>取れたものは捨てずに保管してください</li>
            <li>硬いもの、くっつくものは避けます</li>
            <li>外れた部分を舌や指で触りすぎないようにします</li>
            <li>歯みがきはやさしく続けます</li>
          <li>取れたままにせず、早めに受診してください</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding section-alt">
    <div class="container-narrow">
      <div class="section-kicker">関連する診療</div>
      <h2 class="section-title section-title-left">関連する診療ページ</h2>
      <div class="related-links">
        <a href="/services/cavity/" class="related-card card">
          <span class="related-label">虫歯治療</span>
          <span class="related-copy">再装着だけでなく、虫歯の有無も確認したい方へ</span>
          <span class="related-arrow">→</span>
        </a>
        <a href="/services/preventive/" class="related-card card">
          <span class="related-label">予防歯科</span>
          <span class="related-copy">外れにくい状態を保ちたい、再発を防ぎたい方へ</span>
          <span class="related-arrow">→</span>
        </a>
      </div>
      <div class="reserve-link-wrap">
        <a href="/reserve/" class="btn-primary">早めに受診する</a>
      </div>
    </div>
  </section>

  <SectionCTA
    heading="取れたら早めに。再装着で済むこともあります。"
    text="取れたものがあれば、そのままお持ちください。今は痛くなくても、一度確認しておくと安心です。"
  />
</BaseLayout>

<style>
  .section-kicker {
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .section-title-left {
    text-align: left;
    margin-bottom: 1rem;
  }
  .section-lead {
    max-width: 720px;
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }
  .section-alt {
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, rgba(255,255,255,0) 100%);
  }
  .advice-box,
  .callout {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 28px;
    padding: 1.5rem;
    box-shadow: var(--shadow-card);
  }
  .advice-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1.15rem;
    margin: 0;
  }
  .advice-list li {
    padding-left: 1.35rem;
    position: relative;
  }
  .advice-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.42rem;
    width: 0.7rem;
    height: 0.7rem;
    background: var(--color-accent);
    border-radius: 999px;
  }
  .advice-list strong {
    display: block;
    font-size: 1.02rem;
    margin-bottom: 0.25rem;
    color: var(--color-text-heading);
  }
  .advice-list p {
    font-size: 0.94rem;
    line-height: 1.75;
    color: var(--color-text-light);
    margin: 0;
  }
  .list {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.85rem;
    color: var(--color-text);
  }
  .compact {
    gap: 0.7rem;
  }
  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .soft-card {
    padding: 1.5rem;
  }
  .soft-card h3 {
    font-size: 1.08rem;
    margin-bottom: 0.6rem;
    color: var(--color-text-heading);
  }
  .soft-card p {
    color: var(--color-text-light);
    line-height: 1.8;
    margin: 0;
  }
  .two-col {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }
  .related-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }
  .related-card {
    display: grid;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-text);
    position: relative;
    overflow: hidden;
  }
  .related-card:hover {
    transform: translateY(-2px);
  }
  .related-label {
    font-weight: 700;
    color: var(--color-text-heading);
  }
  .related-copy {
    color: var(--color-text-light);
    line-height: 1.7;
    padding-right: 2rem;
  }
  .related-arrow {
    position: absolute;
    right: 1.25rem;
    bottom: 1.25rem;
    color: var(--color-accent);
    font-size: 1.2rem;
    font-weight: 700;
  }
  .reserve-link-wrap {
    margin-top: 1.5rem;
  }
  @media (max-width: 900px) {
    .card-grid,
    .two-col,
    .related-links {
      grid-template-columns: 1fr;
    }
  }
</style>
