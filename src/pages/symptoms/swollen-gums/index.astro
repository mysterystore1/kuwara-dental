---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/PageHero.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import SectionCTA from "../../../components/SectionCTA.astro";
---

<BaseLayout
  title="歯茎が腫れた"
  description="歯茎の腫れや出血が気になる方へ。歯周病や親知らずなどの可能性を確認し、必要な対応をご案内します。"
>
  <PageHero
    title="歯茎が腫れた"
    subtitle="歯ぐきから血が出る。気になりますよね。"
    image="/images/stock/asian-consultation.jpg"
  />

  <div class="container-narrow">
    <Breadcrumb items={[{ label: "症状から探す" }, { label: "歯茎が腫れた" }]} />
  </div>

  <section class="section-padding">
    <div class="container-narrow">
      <div class="section-kicker">症状について</div>
      <h2 class="section-title section-title-left">腫れや出血は、早めに見せた方が安心です。</h2>
      <p class="section-lead">
        歯ぐきの腫れや出血は、歯周病のサインであることが少なくありません。
        まだ強い痛みがなくても、早めに見せていただく方が整えやすくなります。
      </p>
      <div class="symptom-grid">
        <div class="info-panel">
          <ul class="list">
            <li>歯茎が赤く腫れている</li>
            <li>歯みがきのたびに出血する</li>
            <li>歯茎を押すと痛い、膿が出る</li>
            <li>歯茎が下がってきた気がする</li>
            <li>口臭が気になるようになった</li>
            <li>奥歯の周囲だけ繰り返し腫れる</li>
          </ul>
        </div>
        <div class="note-card">
          <p class="eyebrow">まずは炎症の場所を見分けます</p>
          <p>
            腫れの原因は歯周病だけではありません。歯の根の炎症や、詰め物の不具合が関係していることもあります。
            見た目だけでは判断しにくいため、まずは炎症の場所を確認します。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding section-alt">
    <div class="container-narrow">
      <div class="section-kicker">考えられる原因</div>
      <h2 class="section-title section-title-left">考えられる原因</h2>
      <div class="card-grid">
        <article class="soft-card card">
          <h3>歯周病</h3>
          <p>歯と歯茎の間に細菌がたまることで炎症が起こり、腫れや出血の原因になります。</p>
        </article>
        <article class="soft-card card">
          <h3>歯の根の炎症</h3>
          <p>過去に治療した歯でも、根の先に炎症や膿がたまることで歯茎が腫れることがあります。</p>
        </article>
        <article class="soft-card card">
          <h3>親知らずの周囲炎</h3>
          <p>親知らずの周囲に汚れがたまりやすい場合、腫れや痛みが出やすくなります。</p>
        </article>
        <article class="soft-card card">
          <h3>ブラッシングの刺激</h3>
          <p>強すぎるブラッシングや合わない清掃方法で、歯茎が傷つくこともあります。</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-narrow two-col">
      <div>
      <div class="section-kicker">受診の目安</div>
        <h2 class="section-title section-title-left">受診の目安</h2>
        <div class="callout">
          <ul class="list compact">
            <li>腫れが何日も引かない</li>
            <li>血や膿のようなものが出る</li>
            <li>触ると違和感や痛みがある</li>
            <li>口臭が強くなった気がする</li>
            <li>歯みがきのたびに出血する</li>
          </ul>
        </div>
      </div>
      <div>
        <div class="section-kicker">ご自宅での対応</div>
        <h2 class="section-title section-title-left">応急的な考え方</h2>
        <div class="callout">
          <ul class="list compact">
            <li>腫れていても歯みがきはやめないでください</li>
            <li>出血があっても、やさしく磨きます</li>
            <li>強い刺激のうがい薬を続けすぎないようにします</li>
            <li>自分で押して膿を出そうとしないでください</li>
            <li>気になる状態なら早めにご相談ください</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding section-alt">
    <div class="container-narrow">
      <div class="section-kicker">関連する診療</div>
      <h2 class="section-title section-title-left">関連する診療ページ</h2>
      <div class="related-links">
        <a href="/services/periodontal/" class="related-card card">
          <span class="related-label">歯周病治療</span>
          <span class="related-copy">腫れや出血が歯周病と関係しているか確認したい方へ</span>
          <span class="related-arrow">→</span>
        </a>
        <a href="/services/preventive/" class="related-card card">
          <span class="related-label">予防歯科</span>
          <span class="related-copy">再発を防ぐためのケアを整えたい方へ</span>
          <span class="related-arrow">→</span>
        </a>
      </div>
      <div class="reserve-link-wrap">
        <a href="/reserve/" class="btn-primary">早めに状態を見せる</a>
      </div>
    </div>
  </section>

  <SectionCTA
    heading="歯ぐきの腫れは、早めの確認が安心です。"
    text="出血や腫れが続くときは、歯周病や根の炎症が隠れていることもあります。まずは一度見せてください。"
  />
</BaseLayout>

<style>
  .section-kicker {
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .section-title-left {
    text-align: left;
    margin-bottom: 1rem;
  }
  .section-lead {
    max-width: 720px;
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }
  .section-alt {
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, rgba(255,255,255,0) 100%);
  }
  .symptom-grid,
  .two-col {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }
  .info-panel,
  .note-card,
  .callout {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 28px;
    padding: 1.5rem;
    box-shadow: var(--shadow-card);
  }
  .note-card {
    display: grid;
    align-content: start;
    background: linear-gradient(180deg, rgba(43, 107, 138, 0.06), rgba(255,255,255,1));
  }
  .eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .list {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.85rem;
    color: var(--color-text);
  }
  .compact {
    gap: 0.7rem;
  }
  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .soft-card {
    padding: 1.5rem;
  }
  .soft-card h3 {
    font-size: 1.08rem;
    margin-bottom: 0.6rem;
    color: var(--color-text-heading);
  }
  .soft-card p {
    color: var(--color-text-light);
    line-height: 1.8;
    margin: 0;
  }
  .related-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }
  .related-card {
    display: grid;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-text);
    position: relative;
    overflow: hidden;
  }
  .related-card:hover {
    transform: translateY(-2px);
  }
  .related-label {
    font-weight: 700;
    color: var(--color-text-heading);
  }
  .related-copy {
    color: var(--color-text-light);
    line-height: 1.7;
    padding-right: 2rem;
  }
  .related-arrow {
    position: absolute;
    right: 1.25rem;
    bottom: 1.25rem;
    color: var(--color-accent);
    font-size: 1.2rem;
    font-weight: 700;
  }
  .reserve-link-wrap {
    margin-top: 1.5rem;
  }
  @media (max-width: 900px) {
    .symptom-grid,
    .two-col,
    .card-grid,
    .related-links {
      grid-template-columns: 1fr;
    }
  }
</style>
