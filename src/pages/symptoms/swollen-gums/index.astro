---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHero from "../../../components/PageHero.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import SectionCTA from "../../../components/SectionCTA.astro";
---

<BaseLayout
  title="歯茎が腫れた"
  description="歯茎の腫れや出血が気になる方へ。歯周病や親知らずなどの可能性を確認し、必要な対応をご案内します。"
>
  <PageHero
    title="歯茎が腫れた"
    subtitle="腫れや出血の原因を確認し、必要な対応をご案内します"
    image="https://images.unsplash.com/photo-1598256989800-fe5f95da9787?w=1600&q=80&auto=format&fit=crop"
  />

  <div class="container-narrow">
    <Breadcrumb items={[{ label: "症状から探す" }, { label: "歯茎が腫れた" }]} />
  </div>

  <section class="section-padding">
    <div class="container-narrow">
      <div class="section-kicker">Symptoms</div>
      <h2 class="section-title section-title-left">こんな症状がある方へ</h2>
      <p class="section-lead">
        歯茎の腫れは、見た目の変化だけでなく、出血や口臭、痛みを伴うことがあります。小さな違和感のうちに確認しておくと安心です。
      </p>
      <div class="symptom-grid">
        <div class="info-panel">
          <ul class="list">
            <li>歯茎が赤く腫れている</li>
            <li>歯みがきのたびに出血する</li>
            <li>歯茎を押すと痛い、膿が出る</li>
            <li>歯茎が下がってきた気がする</li>
            <li>口臭が気になるようになった</li>
            <li>奥歯の周囲だけ繰り返し腫れる</li>
          </ul>
        </div>
        <div class="note-card">
          <p class="eyebrow">確認したいこと</p>
          <p>
            腫れは歯周病だけでなく、歯の根の炎症や親知らずの周囲炎でも起こります。痛みが軽くても早めの確認が勧められます。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding section-alt">
    <div class="container-narrow">
      <div class="section-kicker">Causes</div>
      <h2 class="section-title section-title-left">考えられる原因</h2>
      <div class="card-grid">
        <article class="soft-card card">
          <h3>歯周病</h3>
          <p>歯と歯茎の間に細菌がたまることで炎症が起こり、腫れや出血の原因になります。</p>
        </article>
        <article class="soft-card card">
          <h3>歯の根の炎症</h3>
          <p>過去に治療した歯でも、根の先に炎症や膿がたまることで歯茎が腫れることがあります。</p>
        </article>
        <article class="soft-card card">
          <h3>親知らずの周囲炎</h3>
          <p>親知らずの周囲に汚れがたまりやすい場合、腫れや痛みが出やすくなります。</p>
        </article>
        <article class="soft-card card">
          <h3>ブラッシングの刺激</h3>
          <p>強すぎるブラッシングや合わない清掃方法で、歯茎が傷つくこともあります。</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-narrow two-col">
      <div>
        <div class="section-kicker">When to visit</div>
        <h2 class="section-title section-title-left">受診の目安</h2>
        <div class="callout">
          <ul class="list compact">
            <li>腫れが数日以上続いている</li>
            <li>出血や痛みを伴っている</li>
            <li>膿が出る、口臭が強くなった</li>
            <li>同じ場所が繰り返し腫れる</li>
            <li>発熱や開口しづらさがある</li>
          </ul>
        </div>
      </div>
      <div>
        <div class="section-kicker">At home</div>
        <h2 class="section-title section-title-left">応急的な考え方</h2>
        <div class="callout">
          <ul class="list compact">
            <li>腫れている部分を強く押さない</li>
            <li>清掃はやさしく続ける</li>
            <li>熱い刺激や飲酒は控える</li>
            <li>膿や出血があっても自己判断でつぶさない</li>
            <li>早めに原因を確認し、必要な治療を受ける</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding section-alt">
    <div class="container-narrow">
      <div class="section-kicker">Related care</div>
      <h2 class="section-title section-title-left">関連する診療案内</h2>
      <div class="related-links">
        <a href="/services/periodontal/" class="related-card card">
          <span class="related-label">歯周病治療</span>
          <span class="related-copy">腫れや出血が歯周病と関係しているか確認したい方へ</span>
          <span class="related-arrow">→</span>
        </a>
        <a href="/services/preventive/" class="related-card card">
          <span class="related-label">予防歯科</span>
          <span class="related-copy">再発を防ぐためのケアを整えたい方へ</span>
          <span class="related-arrow">→</span>
        </a>
      </div>
      <div class="reserve-link-wrap">
        <a href="/reserve/" class="btn-primary">ご予約・ご相談はこちら</a>
      </div>
    </div>
  </section>

  <SectionCTA
    heading="腫れや出血は早めの確認が安心です"
    text="原因によって必要な対応は変わります。症状が軽いうちでも、気になる場合はご相談ください。"
  />
</BaseLayout>

<style>
  .section-kicker {
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .section-title-left {
    text-align: left;
    margin-bottom: 1rem;
  }
  .section-lead {
    max-width: 720px;
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }
  .section-alt {
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, rgba(255,255,255,0) 100%);
  }
  .symptom-grid,
  .two-col {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }
  .info-panel,
  .note-card,
  .callout {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 28px;
    padding: 1.5rem;
    box-shadow: var(--shadow-card);
  }
  .note-card {
    display: grid;
    align-content: start;
    background: linear-gradient(180deg, rgba(43, 107, 138, 0.06), rgba(255,255,255,1));
  }
  .eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    font-weight: 700;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }
  .list {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.85rem;
    color: var(--color-text);
  }
  .compact {
    gap: 0.7rem;
  }
  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .soft-card {
    padding: 1.5rem;
  }
  .soft-card h3 {
    font-size: 1.08rem;
    margin-bottom: 0.6rem;
    color: var(--color-text-heading);
  }
  .soft-card p {
    color: var(--color-text-light);
    line-height: 1.8;
    margin: 0;
  }
  .related-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }
  .related-card {
    display: grid;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-text);
    position: relative;
    overflow: hidden;
  }
  .related-card:hover {
    transform: translateY(-2px);
  }
  .related-label {
    font-weight: 700;
    color: var(--color-text-heading);
  }
  .related-copy {
    color: var(--color-text-light);
    line-height: 1.7;
    padding-right: 2rem;
  }
  .related-arrow {
    position: absolute;
    right: 1.25rem;
    bottom: 1.25rem;
    color: var(--color-accent);
    font-size: 1.2rem;
    font-weight: 700;
  }
  .reserve-link-wrap {
    margin-top: 1.5rem;
  }
  @media (max-width: 900px) {
    .symptom-grid,
    .two-col,
    .card-grid,
    .related-links {
      grid-template-columns: 1fr;
    }
  }
</style>
